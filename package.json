{
  "name": "@chaosity/address-form",
  "description": "Address Form SDK for Chaosity Location Service",
  "version": "0.2.0",
  "main": "./dist/lib/address-form-sdk.cjs.js",
  "types": "dist/lib/main.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chaosity-io/address-form-sdk-js"
  },
  "scripts": {
    "dev": "vite",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build": "npm run build:lib && npm run build:standalone",
    "build:lib": "tsc -b && vite build",
    "build:standalone": "tsc -b && vite build --config ./vite.config.standalone.ts",
    "build:storybook": "storybook build",
    "test": "vitest run --coverage",
    "format": "prettier --write .",
    "prepare": "husky",
    "postversion": "git push --follow-tags"
  },
  "devDependencies": {
    "@chaosity/location-client": "^0.1.0",
    "@chaosity/location-client-react": "^0.1.0",
    "@eslint/js": "^10",
    "@storybook/react-vite": "^10",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/lodash": "^4.17.20",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vanilla-extract/vite-plugin": "^5.0.1",
    "@vitejs/plugin-react": "^6",
    "@vitest/coverage-v8": "^4",
    "eslint": "^10",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-storybook": "^10",
    "glob": "^13.0.0",
    "globals": "^17.0.0",
    "husky": "^9.0.0",
    "jsdom": "^29",
    "jsdom-testing-mocks": "^1.13.1",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^10.3.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.2",
    "@tanstack/react-query": "^5.81.5",
    "@vanilla-extract/css": "^1.17.1",
    "clsx": "^2.1.1",
    "maplibre-gl": "^5.4.0",
    "react-hook-form": "^7.57.0",
    "react-map-gl": "^8.0.4",
    "zustand": "^5.0.8"
  },
  "peerDependencies": {
    "@chaosity/location-client": ">=0.1.0",
    "@chaosity/location-client-react": ">=0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
